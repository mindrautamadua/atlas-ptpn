model KpiKaryawanItem {
  id        BigInt   @id @default(autoincrement())
  kode      String   @db.VarChar(30)
  nama      String
  userId    BigInt   @map("user_id")
  unitCode  String?  @map("unit_code") @db.VarChar(20)
  satuan    String   @db.VarChar(30)
  polaritas String   @default("maximize") @db.VarChar(10)
  bobot     Decimal  @default(0) @db.Decimal(5, 2)
  definisi  String?  @db.Text
  tahun     Int      @db.SmallInt
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user   User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  values KpiKaryawanValue[]

  @@map("kpi_karyawan_items")
  @@schema("ptpn_kmr_app")
}

model KpiKaryawanValue {
  id                BigInt   @id @default(autoincrement())
  kpiKaryawanItemId BigInt   @map("kpi_karyawan_item_id")
  periodId          BigInt   @map("period_id")
  target            Decimal? @db.Decimal(18, 4)
  realisasi         Decimal? @db.Decimal(18, 4)
  skor              Decimal? @db.Decimal(8, 4)
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  kpiKaryawanItem KpiKaryawanItem   @relation(fields: [kpiKaryawanItemId], references: [id], onDelete: Cascade)
  period          PerformancePeriod @relation(fields: [periodId], references: [id], onDelete: Cascade)

  @@map("kpi_karyawan_values")
  @@unique([kpiKaryawanItemId, periodId])
  @@schema("ptpn_kmr_app")
}

model KpiDivisiItem {
  id                 BigInt   @id @default(autoincrement())
  unitId             BigInt   @map("unit_id")
  directorateId      BigInt   @map("directorate_id")
  kode               String   @db.VarChar(30)
  nama               String
  strategicObjective String?  @map("strategic_objective")
  perspektif         String   @db.VarChar(40)
  satuan             String   @db.VarChar(30)
  polaritas          String   @default("maximize") @db.VarChar(10)
  bobot              Decimal  @default(0) @db.Decimal(5, 2)
  formula            String?  @db.Text
  sumberData         String?  @map("sumber_data")
  tahun              Int      @db.SmallInt
  urutan             Int      @default(0) @db.SmallInt
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  unit        OrganizationalUnit @relation(fields: [unitId], references: [id], onDelete: Cascade)
  directorate Directorate        @relation(fields: [directorateId], references: [id], onDelete: Cascade)
  values      KpiDivisiValue[]

  @@map("kpi_divisi_items")
  @@unique([unitId, tahun, kode])
  @@index([directorateId, tahun])
  @@schema("ptpn_kmr_app")
}

model KpiDivisiValue {
  id              BigInt   @id @default(autoincrement())
  kpiDivisiItemId BigInt   @map("kpi_divisi_item_id")
  periodId        BigInt   @map("period_id")
  target          Decimal? @db.Decimal(18, 4)
  realisasi       Decimal? @db.Decimal(18, 4)
  skor            Decimal? @db.Decimal(8, 4)
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  kpiDivisiItem KpiDivisiItem     @relation(fields: [kpiDivisiItemId], references: [id], onDelete: Cascade)
  period        PerformancePeriod @relation(fields: [periodId], references: [id], onDelete: Cascade)

  @@map("kpi_divisi_values")
  @@unique([kpiDivisiItemId, periodId])
  @@schema("ptpn_kmr_app")
}

model Cache {
  key        String @id
  value      String @db.Text
  expiration Int

  @@map("cache")
  @@schema("ptpn_kmr_app")
}

model CacheLock {
  key        String @id
  owner      String
  expiration Int

  @@map("cache_locks")
  @@schema("ptpn_kmr_app")
}
