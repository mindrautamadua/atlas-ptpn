  directorateCode String   @map("directorate_code") @db.VarChar(10)
  perspektif      String   @db.VarChar(40)
  satuan          String   @db.VarChar(30)
  polaritas       String   @default("maximize") @db.VarChar(10)
  bobot           Decimal  @default(0) @db.Decimal(5, 2)
