generator client {
  provider        = "prisma-client-js"
  output          = "../src/generated/prisma"
  previewFeatures = ["partialIndexes"]
}

datasource db {
  provider = "postgresql"
  schemas  = ["ptpn_kmr_app"]
}

model Directorate {
  id                   Int                   @id @default(autoincrement())
  code                 String                @unique(map: "directorate_code_unique") @db.VarChar(255)
  name                 String                @db.VarChar(255)
  shortName            String?               @db.VarChar(255)
  corporateName        String?               @db.VarChar(255)
  corporateCode        String?               @db.VarChar(255)
  corporateId          String?               @db.VarChar(255)
  domain               String?               @db.VarChar(255)
  isActive             Boolean               @default(true)
  createdAt            DateTime              @default(now()) @db.Timestamp(0)
  updatedAt            DateTime              @default(now()) @updatedAt @db.Timestamp(0)
  direktoratScorecards DirektoratScorecard[]
  divisiScorecards     DivisiScorecard[]
  organizationalUnits  OrganizationalUnit[]
  positions            Position[]
  users                User[]
  kpiDivisiItems       KpiDivisiItem[]

  @@schema("ptpn_kmr_app")
}

model OrganizationalUnit {
  id                 Int                  @id @default(autoincrement())
  code               String               @unique(map: "organizationalunit_code_unique") @db.VarChar(255)
  name               String               @db.VarChar(255)
  description        String?
  unitType           String               @db.VarChar(255)
  parentId           Int?
  headId             Int?
  budget             Decimal?             @db.Decimal(20, 4)
  isActive           Boolean              @default(true)
  createdAt          DateTime             @default(now()) @db.Timestamp(0)
  directorateId      Int?
  divisiScorecards   DivisiScorecard[]
  monthlyReports     MonthlyReport[]
  directorate        Directorate?         @relation(fields: [directorateId], references: [id], onUpdate: NoAction, map: "organizationalunit_directorateid_foreign")
  parent             OrganizationalUnit?  @relation("OrganizationalUnitParent", fields: [parentId], references: [id], onUpdate: NoAction, map: "organizationalunit_parentid_foreign")
  children           OrganizationalUnit[] @relation("OrganizationalUnitParent")
  positions          Position[]
  riskMonthlyReports RiskMonthlyReport[]
  users              User[]
  kpiDivisiItems     KpiDivisiItem[]

  @@index([directorateId], map: "organizationalunit_directorateid_index")
  @@index([parentId], map: "organizationalunit_parentid_index")
  @@index([unitType], map: "organizationalunit_unittype_index")
  @@schema("ptpn_kmr_app")
}

model Position {
  id                  Int                 @id @default(autoincrement())
  code                String              @unique(map: "position_code_unique") @db.VarChar(255)
  name                String              @db.VarChar(255)
  levelCode           String              @db.VarChar(255)
  roleType            String              @db.VarChar(255)
  directorateId       Int?
  divisionId          Int?
  reportsToPositionId Int?
  sourceUnitId        Int?                @unique(map: "position_sourceunitid_unique")
  seatOrder           Int?
  isActive            Boolean             @default(true)
  createdAt           DateTime            @default(now()) @db.Timestamp(0)
  updatedAt           DateTime            @default(now()) @updatedAt @db.Timestamp(0)
  directorate         Directorate?        @relation(fields: [directorateId], references: [id], onUpdate: NoAction, map: "position_directorateid_foreign")
  division            OrganizationalUnit? @relation(fields: [divisionId], references: [id], onUpdate: NoAction, map: "position_divisionid_foreign")
  reportsToPosition   Position?           @relation("PositionReportsTo", fields: [reportsToPositionId], references: [id], onUpdate: NoAction, map: "position_reportstopositionid_foreign")
  reportingPositions  Position[]          @relation("PositionReportsTo")
  users               User[]
  positionHistories   PositionHistory[]

  @@index([directorateId], map: "position_directorateid_index")
  @@index([divisionId], map: "position_divisionid_index")
  @@index([levelCode], map: "position_levelcode_index")
  @@index([reportsToPositionId], map: "position_reportstopositionid_index")
  @@index([roleType], map: "position_roletype_index")
  @@schema("ptpn_kmr_app")
}

model RoleConfig {
  role        String   @id @db.VarChar(255)
  label       String   @db.VarChar(255)
  description String   @default("") @db.VarChar(255)
  line        String?  @db.VarChar(255)
  bodLevel    String?  @db.VarChar(255)
  badgeColor  String   @default("bg-gray-100 text-gray-600") @db.VarChar(255)
  updatedAt   DateTime @default(now()) @updatedAt @db.Timestamp(0)

  @@map("role_configs")
  @@schema("ptpn_kmr_app")
}

model User {
  id                      Int                      @id @default(autoincrement())
  email                   String                   @unique(map: "user_email_unique") @db.VarChar(255)
  name                    String                   @db.VarChar(255)
  phone                   String?                  @db.VarChar(255)
  roleType                String                   @db.VarChar(255)
  unitId                  Int?
  avatarUrl               String?                  @db.VarChar(255)
  isActive                Boolean                  @default(true)
  preferences             Json?                    @db.Json
  createdAt               DateTime                 @default(now()) @db.Timestamp(0)
  updatedAt               DateTime                 @default(now()) @updatedAt @db.Timestamp(0)
  userId                  String?                  @unique(map: "user_userid_unique") @db.VarChar(255)
  nik                     String?                  @unique(map: "user_nik_unique") @db.VarChar(255)
  directorateId           Int?
  positionId              Int?
  managerUserId           Int?
  positionTitle           String?                  @db.VarChar(255)
  availableRoles          String?                  @db.VarChar(255)
  passwordHash            String?                  @db.VarChar(255)
  toursCompleted          Json?                    @db.Json
  assignmentsReceived     Assignment[]             @relation("AssignmentAssignee")
  assignmentsAssigned     Assignment[]             @relation("AssignmentAssigner")
  assignmentAttachments   AssignmentAttachment[]
  assignmentReviewActions AssignmentReviewAction[]
  channelMembers          ChannelMember[]
  channelMessages         ChannelMessage[]
  channelMessageHiddens   ChannelMessageHidden[]
  comments                Comment[]
  escalationsEscalatedTo  EscalationRequest[]      @relation("EscalationEscalatedTo")
  escalationsRequested    EscalationRequest[]      @relation("EscalationRequestedBy")
  escalationsReroutedTo   EscalationRequest[]      @relation("EscalationReroutedTo")
  FocusDisposition        FocusDisposition[]
  formDrafts              FormDraft[]
  kpiValueRevisions       KpiValueRevision[]
  messageReminders        MessageReminder[]
  monthlyReportsSubmitted MonthlyReport[]
  monthlyReportApprovals  MonthlyReportApproval[]
  monthlyReportFiles      MonthlyReportFile[]
  notifications           Notification[]
  programApprovalLogs     ProgramApprovalLog[]
  programProgressLogs     ProgramProgressLog[]
  riskReportsCreated      RiskMonthlyReport[]      @relation("RiskReportCreatedBy")
  riskReportsSubmitted    RiskMonthlyReport[]      @relation("RiskReportSubmittedBy")
  riskReportApprovals     RiskReportApproval[]
  savedMessages           SavedMessage[]
  savedSearches           SavedSearch[]
  systemSettings          SystemSetting[]
  directorate             Directorate?             @relation(fields: [directorateId], references: [id], onUpdate: NoAction, map: "user_directorateid_foreign")
  manager                 User?                    @relation("UserManager", fields: [managerUserId], references: [id], onUpdate: NoAction, map: "user_manageruserid_foreign")
  reports                 User[]                   @relation("UserManager")
  position                Position?                @relation(fields: [positionId], references: [id], onUpdate: NoAction, map: "user_positionid_foreign")
  unit                    OrganizationalUnit?      @relation(fields: [unitId], references: [id], onUpdate: NoAction, map: "user_unitid_foreign")
  userSessions            UserSession[]
  userStatus              UserStatus?
  workItemStatusLogs      WorkItemStatusLog[]
  entityPics              EntityPic[]
  kpiKaryawanItems        KpiKaryawanItem[]
  positionHistories       PositionHistory[]

  @@index([directorateId], map: "user_directorateid_index")
  @@index([managerUserId], map: "user_manageruserid_index")
  @@index([nik], map: "user_nik_index")
  @@index([positionId], map: "user_positionid_index")
  @@index([roleType], map: "user_roletype_index")
  @@index([unitId], map: "user_unitid_index")
  @@index([userId], map: "user_userid_index")
  @@schema("ptpn_kmr_app")
}

model UserStatus {
  id             Int      @id @default(autoincrement())
  userId         Int      @unique(map: "userstatus_userid_unique")
  status         String   @db.VarChar(255)
  statusEmoji    String?  @db.VarChar(255)
  statusMessage  String?  @db.VarChar(255)
  lastActivityAt DateTime @default(now()) @db.Timestamp(0)
  updatedAt      DateTime @default(now()) @updatedAt @db.Timestamp(0)
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "userstatus_userid_foreign")

  @@schema("ptpn_kmr_app")
}

model UserSession {
  id         Int       @id @default(autoincrement())
  userId     Int
  startedAt  DateTime  @default(now()) @db.Timestamp(0)
  endedAt    DateTime? @db.Timestamp(0)
  durationMs Int       @default(0)
  lastPingAt DateTime  @default(now()) @db.Timestamp(0)
  endReason  String?   @db.VarChar(255)
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "usersession_userid_foreign")

  @@index([endedAt], map: "usersession_endedat_index")
  @@index([startedAt], map: "usersession_startedat_index")
  @@index([userId], map: "usersession_userid_index")
  @@schema("ptpn_kmr_app")
}

model PositionHistory {
  id             Int       @id @default(autoincrement())
  userId         Int
  positionId     Int
  startDate      DateTime  @db.Timestamp(0)
  endDate        DateTime? @db.Timestamp(0)
  mutationType   String    @default("initial_assignment") @db.VarChar(255)
  mutationReason String?   @db.VarChar(255)
  skNumber       String?   @db.VarChar(255)
  createdBy      Int?
  createdAt      DateTime  @default(now()) @db.Timestamp(0)
  position       Position  @relation(fields: [positionId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "position_history_positionid_foreign")
  user           User      @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "position_history_userid_foreign")

  @@map("position_history")
  @@schema("ptpn_kmr_app")
}

model Program {
  id                    Int                    @id @default(autoincrement())
  code                  String                 @unique(map: "program_code_unique") @db.VarChar(255)
  name                  String                 @db.VarChar(255)
  description           String?
  strategicObjective    String?
  ownerId               Int
  ownerUnitId           Int?
  status                String                 @default("PLANNING") @db.VarChar(255)
  priority              String                 @default("MEDIUM") @db.VarChar(255)
  budgetIdr             Decimal?               @db.Decimal(20, 4)
  budgetSpent           Decimal?               @default(0) @db.Decimal(20, 4)
  startDate             DateTime               @db.Timestamp(0)
  targetEndDate         DateTime               @db.Timestamp(0)
  actualEndDate         DateTime?              @db.Timestamp(0)
  progressPercent       Int                    @default(0)
  strategicAlignment    Float?
  healthStatus          String?                @db.VarChar(255)
  linkedChannelId       Int?
  createdAt             DateTime               @default(now()) @db.Timestamp(0)
  updatedAt             DateTime               @default(now()) @updatedAt @db.Timestamp(0)
  hasNoApmsKpi          Boolean                @default(false)
  approvalStatus        String                 @default("ACTIVE") @db.VarChar(255)
  rejectionNote         String?
  submittedById         Int?
  archivedAt            DateTime?              @db.Timestamp(0)
  archivedById          Int?
  kelompok              String?                @db.VarChar(255)
  pilarStrategis        String?                @db.VarChar(255)
  progresTerkini        String?
  dukunganDibutuhkan    String?
  autoHealthComputedAt  DateTime?              @db.Timestamp(0)
  assignments           Assignment[]
  escalationRequests    EscalationRequest[]
  FocusDisposition      FocusDisposition[]
  initiatives           Initiative[]
  kpiDefinitions        KpiDefinition[]
  programApprovalLogs   ProgramApprovalLog[]
  programKpiLinks       ProgramKpiLink[]
  programProgressLogs   ProgramProgressLog[]
  monthlyReportPrograms MonthlyReportProgram[]

  @@index([ownerUnitId], map: "Program_active_partial_idx", where: raw("(\"archivedAt\" IS NULL)"))
  @@index([approvalStatus])
  @@index([ownerUnitId, approvalStatus])
  @@index([healthStatus], map: "program_healthstatus_index")
  @@index([kelompok], map: "program_kelompok_index")
  @@index([ownerId], map: "program_ownerid_index")
  @@index([pilarStrategis], map: "program_pilarstrategis_index")
  @@index([startDate], map: "program_startdate_index")
  @@index([status], map: "program_status_index")
  @@schema("ptpn_kmr_app")
}

model Initiative {
  id                 Int        @id @default(autoincrement())
  code               String     @unique(map: "initiative_code_unique") @db.VarChar(255)
  programId          Int
  name               String     @db.VarChar(255)
  description        String?
  ownerId            Int
  ownerUnitId        Int?
  status             String     @default("BACKLOG") @db.VarChar(255)
  priority           String     @default("MEDIUM") @db.VarChar(255)
  startDate          DateTime?  @db.Timestamp(0)
  targetCompletion   DateTime   @db.Timestamp(0)
  actualCompletion   DateTime?  @db.Timestamp(0)
  progressPercent    Int        @default(0)
  milestones         Json?      @db.Json
  healthStatus       String?    @db.VarChar(255)
  riskLevel          String?    @db.VarChar(255)
  linkedChannelId    Int?
  createdAt          DateTime   @default(now()) @db.Timestamp(0)
  updatedAt          DateTime   @default(now()) @updatedAt @db.Timestamp(0)
  primaryPicPersonId Int?
  budgetIdr          Decimal?   @db.Decimal(20, 4)
  budgetSpent        Decimal?   @default(0) @db.Decimal(20, 4)
  program            Program    @relation(fields: [programId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "initiative_programid_foreign")
  phases             Phase[]
  workItems          WorkItem[]

  @@index([ownerId], map: "initiative_ownerid_index")
  @@index([programId], map: "initiative_programid_index")
  @@index([status], map: "initiative_status_index")
  @@index([targetCompletion], map: "initiative_targetcompletion_index")
  @@schema("ptpn_kmr_app")
}

model Phase {
  id           Int        @id @default(autoincrement())
  code         String     @unique(map: "phase_code_unique") @db.VarChar(255)
  initiativeId Int
  order        Int        @default(0)
  name         String     @db.VarChar(255)
  description  String?
  picUnitIds   Json?      @db.Json
  status       String     @default("PLANNING") @db.VarChar(255)
  color        String?    @db.VarChar(255)
  startWeek    String?    @db.VarChar(255)
  endWeek      String?    @db.VarChar(255)
  healthStatus String?    @db.VarChar(255)
  createdAt    DateTime   @default(now()) @db.Timestamp(0)
  updatedAt    DateTime   @default(now()) @updatedAt @db.Timestamp(0)
  initiative   Initiative @relation(fields: [initiativeId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "phase_initiativeid_foreign")
  workItems    WorkItem[]

  @@index([initiativeId], map: "phase_initiativeid_index")
  @@index([order], map: "phase_order_index")
  @@index([status], map: "phase_status_index")
  @@schema("ptpn_kmr_app")
}

model WorkItem {
  id                 Int                 @id @default(autoincrement())
  code               String              @unique(map: "workitem_code_unique") @db.VarChar(255)
  initiativeId       Int
  title              String              @db.VarChar(255)
  description        String?
  assignedTo         Int?
  createdBy          Int
  createdByUnitId    Int?
  status             String              @default("BACKLOG") @db.VarChar(255)
  priority           String              @default("MEDIUM") @db.VarChar(255)
  percentComplete    Int                 @default(0)
  startDate          DateTime?           @db.Timestamp(0)
  targetCompletion   DateTime            @db.Timestamp(0)
  actualCompletion   DateTime?           @db.Timestamp(0)
  dependsOnIds       Json?               @db.Json
  estimatedHours     Float?
  actualHours        Float?              @default(0)
  healthStatus       String?             @db.VarChar(255)
  isBlocked          Boolean             @default(false)
  blockedReason      String?
  linkedThreadId     Int?
  createdAt          DateTime            @default(now()) @db.Timestamp(0)
  updatedAt          DateTime            @default(now()) @updatedAt @db.Timestamp(0)
  actualWeeks        Json?               @db.Json
  letterIndex        String?             @db.VarChar(255)
  phaseId            Int?
  picUnitIds         Json?               @db.Json
  plannedWeeks       Json?               @db.Json
  output             String?
  blockers           Blocker[]
  subTasks           SubTask[]
  initiative         Initiative          @relation(fields: [initiativeId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "workitem_initiativeid_foreign")
  phase              Phase?              @relation(fields: [phaseId], references: [id], onUpdate: NoAction, map: "workitem_phaseid_foreign")
  workItemStatusLogs WorkItemStatusLog[]

  @@index([assignedTo], map: "workitem_assignedto_index")
  @@index([healthStatus], map: "workitem_healthstatus_index")
  @@index([initiativeId], map: "workitem_initiativeid_index")
  @@index([isBlocked], map: "workitem_isblocked_index")
  @@index([phaseId], map: "workitem_phaseid_index")
  @@index([status], map: "workitem_status_index")
  @@index([targetCompletion], map: "workitem_targetcompletion_index")
  @@schema("ptpn_kmr_app")
}

model SubTask {
  id          Int       @id @default(autoincrement())
  workItemId  Int
  title       String    @db.VarChar(255)
  description String?
  assignedTo  Int?
  status      String    @default("PENDING") @db.VarChar(255)
  isCompleted Boolean   @default(false)
  completedAt DateTime? @db.Timestamp(0)
  dueDate     DateTime? @db.Timestamp(0)
  createdAt   DateTime  @default(now()) @db.Timestamp(0)
  updatedAt   DateTime  @default(now()) @updatedAt @db.Timestamp(0)
  workItem    WorkItem  @relation(fields: [workItemId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "subtask_workitemid_foreign")

  @@index([assignedTo], map: "subtask_assignedto_index")
  @@index([workItemId], map: "subtask_workitemid_index")
  @@schema("ptpn_kmr_app")
}

model Blocker {
  id                Int       @id @default(autoincrement())
  code              String    @unique(map: "blocker_code_unique") @db.VarChar(255)
  workItemId        Int
  title             String    @db.VarChar(255)
  description       String?
  severity          String    @db.VarChar(255)
  createdBy         Int
  createdByUnitId   Int?
  assignedTo        Int?
  status            String    @default("OPEN") @db.VarChar(255)
  priority          String    @default("HIGH") @db.VarChar(255)
  rootCause         String?
  resolution        String?
  resolvedAt        DateTime? @db.Timestamp(0)
  resolutionTime    Int?
  relatedBlockerIds Json?     @db.Json
  linkedWorkItemIds Json?     @db.Json
  linkedChannelId   Int?
  createdAt         DateTime  @default(now()) @db.Timestamp(0)
  updatedAt         DateTime  @default(now()) @updatedAt @db.Timestamp(0)
  workItem          WorkItem  @relation(fields: [workItemId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "blocker_workitemid_foreign")

  @@index([assignedTo], map: "blocker_assignedto_index")
  @@index([severity], map: "blocker_severity_index")
  @@index([status], map: "blocker_status_index")
  @@index([workItemId], map: "blocker_workitemid_index")
  @@schema("ptpn_kmr_app")
}

model KpiDefinition {
  id                  Int                @id @default(autoincrement())
  code                String             @unique(map: "kpidefinition_code_unique") @db.VarChar(255)
  programId           Int?
  initiativeId        Int?
  name                String             @db.VarChar(255)
  description         String?
  metricType          String             @db.VarChar(255)
  dataType            String             @db.VarChar(255)
  targetValue         Decimal            @db.Decimal(20, 6)
  actualValue         Decimal?           @db.Decimal(20, 6)
  warningThreshold    Decimal?           @db.Decimal(20, 6)
  criticalThreshold   Decimal?           @db.Decimal(20, 6)
  unitOfMeasure       String?            @db.VarChar(255)
  reviewFrequency     String             @default("MONTHLY") @db.VarChar(255)
  lastMeasuredDate    DateTime?          @db.Timestamp(0)
  ownerId             Int?
  ownerUnitId         Int?
  isLeadingIndicator  Boolean            @default(false)
  leadingIndicatorFor String?            @db.VarChar(255)
  isActive            Boolean            @default(true)
  createdAt           DateTime           @default(now()) @db.Timestamp(0)
  updatedAt           DateTime           @default(now()) @updatedAt @db.Timestamp(0)
  program             Program?           @relation(fields: [programId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "kpidefinition_programid_foreign")
  kpiValues           KpiValue[]
  kpiValueRevisions   KpiValueRevision[]

  @@index([isLeadingIndicator], map: "kpidefinition_isleadingindicator_index")
  @@index([metricType], map: "kpidefinition_metrictype_index")
  @@index([programId], map: "kpidefinition_programid_index")
  @@schema("ptpn_kmr_app")
}

model KpiValue {
  id                Int                @id @default(autoincrement())
  kpiDefinitionId   Int
  measurementDate   DateTime           @db.Timestamp(0)
  targetValue       Decimal?           @db.Decimal(20, 6)
  actualValue       Decimal            @db.Decimal(20, 6)
  status            String?            @db.VarChar(255)
  variance          Decimal?           @db.Decimal(20, 6)
  variancePercent   Float?
  statusNotes       String?
  measuredBy        Int?
  createdAt         DateTime           @default(now()) @db.Timestamp(0)
  updatedAt         DateTime           @default(now()) @updatedAt @db.Timestamp(0)
  kpiDefinition     KpiDefinition      @relation(fields: [kpiDefinitionId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "kpivalue_kpidefinitionid_foreign")
  kpiValueRevisions KpiValueRevision[]

  @@unique([kpiDefinitionId, measurementDate], map: "kpivalue_kpidefinitionid_measurementdate_unique")
  @@index([kpiDefinitionId], map: "kpivalue_kpidefinitionid_index")
  @@index([measurementDate], map: "kpivalue_measurementdate_index")
  @@index([status], map: "kpivalue_status_index")
  @@schema("ptpn_kmr_app")
}

model ProgramKpiLink {
  id           Int      @id @default(autoincrement())
  programId    Int
  apmsKpiCode  String   @db.VarChar(255)
  note         String?
  createdAt    DateTime @default(now()) @db.Timestamp(0)
  apmsKpiBobot Float?
  apmsKpiName  String?  @db.VarChar(255)
  program      Program  @relation(fields: [programId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "programkpilink_programid_foreign")

  @@unique([programId, apmsKpiCode], map: "programkpilink_programid_apmskpicode_unique")
  @@index([apmsKpiCode], map: "programkpilink_apmskpicode_index")
  @@index([programId], map: "programkpilink_programid_index")
  @@schema("ptpn_kmr_app")
}

model Channel {
  id                 Int              @id @default(autoincrement())
  code               String           @unique(map: "channel_code_unique") @db.VarChar(255)
  name               String           @db.VarChar(255)
  description        String?
  type               String           @db.VarChar(255)
  createdBy          Int
  ownerUnitId        Int?
  topicType          String?          @db.VarChar(255)
  linkedProgramId    Int?
  linkedInitiativeId Int?
  isArchived         Boolean          @default(false)
  allowedPostTypes   String?          @db.VarChar(255)
  allowThreads       Boolean          @default(true)
  allowReactions     Boolean          @default(true)
  createdAt          DateTime         @default(now()) @db.Timestamp(0)
  updatedAt          DateTime         @default(now()) @updatedAt @db.Timestamp(0)
  channelMembers     ChannelMember[]
  channelMessages    ChannelMessage[]

  @@index([isArchived], map: "channel_isarchived_index")
  @@index([topicType], map: "channel_topictype_index")
  @@index([type], map: "channel_type_index")
  @@schema("ptpn_kmr_app")
}

model ChannelMember {
  channelId    Int
  userId       Int
  joinedAt     DateTime  @default(now()) @db.Timestamp(0)
  lastViewedAt DateTime? @db.Timestamp(0)
  isMuted      Boolean   @default(false)
  isStarred    Boolean   @default(false)
  channel      Channel   @relation(fields: [channelId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "channelmember_channelid_foreign")
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "channelmember_userid_foreign")

  @@id([channelId, userId])
  @@index([userId])
  @@index([lastViewedAt], map: "channelmember_lastviewedat_index")
  @@schema("ptpn_kmr_app")
}

model ChannelMessage {
  id                   Int                    @id @default(autoincrement())
  channelId            Int
  userId               Int
  content              String
  richContent          Json?                  @db.Json
  attachments          Json?                  @db.Json
  parentMessageId      Int?
  replyCount           Int                    @default(0)
  reactions            Json?                  @db.Json
